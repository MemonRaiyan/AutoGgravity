generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Channel {
  id           String   @id @default(cuid())
  platform     String   // YOUTUBE, META, TELEGRAM
  name         String
  accessToken  String?
  refreshToken String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  videos       Video[]
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  driveUrl    String?
  fileId      String?
  status      String   @default("PENDING") // PENDING, DOWNLOADING, UPLOADING, COMPLETED, FAILED
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id])
  history     UploadHistory[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QueueJob {
  id        String   @id @default(cuid())
  jobId     String   @unique
  status    String   // WAITING, ACTIVE, COMPLETED, FAILED
  type      String   // DOWNLOAD, UPLOAD, AI_PROCESS
  data      String   // JSON string
  result    String?  // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UploadHistory {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  platform  String
  url       String?
  status    String   // SUCCESS, FAILED
  error     String?
  createdAt DateTime @default(now())
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  platform  String
  views     Int      @default(0)
  likes     Int      @default(0)
  shares    Int      @default(0)
  createdAt DateTime @default(now())
}
